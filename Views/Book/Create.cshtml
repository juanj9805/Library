@model library.Models.Book
@{
    ViewData["Title"] = "Nuevo Libro";
}

@section TopbarActions {
    <a href="/Book" class="btn btn-outline-secondary btn-sm">← Volver</a>
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Registrar Libro</div>
            <div class="card-body">
                <form asp-action="Create" asp-controller="Book" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Título</label>
                        <input asp-for="Title" class="form-control" placeholder="Ej: Cien Años de Soledad" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Author" class="form-label">Autor</label>
                        <input asp-for="Author" class="form-control" placeholder="Ej: Gabriel García Márquez" />
                        <span asp-validation-for="Author" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="Status" class="form-check-input" type="checkbox" checked />
                            <label asp-for="Status" class="form-check-label">Disponible para préstamo</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Registrar</button>
                        <a href="/Book" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
