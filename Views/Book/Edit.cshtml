@model library.Models.Book
@{
    ViewData["Title"] = "Editar Libro";
}

@section TopbarActions {
    <a href="/Book" class="btn btn-outline-secondary btn-sm">← Volver</a>
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Editar Libro</span>
                <span class="text-muted small">#@Model.Id</span>
            </div>
            <div class="card-body">
                <form asp-action="Edit" asp-controller="Book" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Título</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Author" class="form-label">Autor</label>
                        <input asp-for="Author" class="form-control" />
                        <span asp-validation-for="Author" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="Status" class="form-check-input" type="checkbox" />
                            <label asp-for="Status" class="form-check-label">Disponible para préstamo</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                        <a href="/Book" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
