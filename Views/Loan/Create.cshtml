@model library.Models.Loan
@{
    ViewData["Title"] = "Nuevo Préstamo";
    var users = ViewBag.Users as IEnumerable<library.Models.User>;
    var books = ViewBag.Books as IEnumerable<library.Models.Book>;
}

@section TopbarActions {
    <a href="/Loan" class="btn btn-outline-secondary btn-sm">← Volver</a>
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Registrar Préstamo</div>
            <div class="card-body">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form asp-action="Create" asp-controller="Loan" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Usuario</label>
                        <select name="UserId" class="form-select" required>
                            <option value="">— Seleccionar usuario —</option>
                            @foreach (var u in users ?? Enumerable.Empty<library.Models.User>())
                            {
                                <option value="@u.Id">@u.Name @u.Lastname — @u.DNI</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Libros a prestar</label>
                        <div class="border rounded p-3" style="max-height: 220px; overflow-y: auto; background: #f8f9fa;">
                            @if (books != null && books.Any(b => b.Status))
                            {
                                @foreach (var book in books.Where(b => b.Status))
                                {
                                    <div class="form-check mb-1">
                                        <input class="form-check-input" type="checkbox" name="bookIds" value="@book.Id" id="book_@book.Id" />
                                        <label class="form-check-label" for="book_@book.Id">
                                            <strong>@book.Title</strong> <span class="text-muted">— @book.Author</span>
                                        </label>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted mb-0 small">No hay libros disponibles en este momento.</p>
                            }
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DateEnd" class="form-label">Fecha de Devolución</label>
                        <input asp-for="DateEnd" type="date" class="form-control" required />
                        <span asp-validation-for="DateEnd" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Registrar Préstamo</button>
                        <a href="/Loan" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
