@model IEnumerable<library.Models.Loan>
@{
    ViewData["Title"] = "Préstamos";
}

@section TopbarActions {
    <a href="/Loan/Create" class="btn btn-primary btn-sm">+ Nuevo Préstamo</a>
}

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Registro de Préstamos</span>
        <span class="text-muted small">@Model.Count() registros</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <p class="mb-1">No hay préstamos registrados.</p>
                <a href="/Loan/Create" class="btn btn-outline-primary btn-sm mt-2">Registrar primero</a>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Usuario</th>
                        <th>Libros</th>
                        <th>Fecha Inicio</th>
                        <th>Fecha Devolución</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var loan in Model)
                    {
                        <tr>
                            <td class="text-muted">@loan.Id</td>
                            <td>@loan.User.Name @loan.User.Lastname</td>
                            <td>
                                @foreach (var lb in loan.LoanBooks)
                                {
                                    <span class="badge bg-light text-dark border me-1">@lb.Book.Title</span>
                                }
                            </td>
                            <td>@loan.DateStart.ToString("dd/MM/yyyy")</td>
                            <td>@loan.DateEnd.ToString("dd/MM/yyyy")</td>
                            <td class="text-end">
                                <form method="post" action="/Loan/Delete/@loan.Id" class="d-inline"
                                      onsubmit="return confirm('¿Eliminar este préstamo?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Eliminar</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
