@model library.Models.User
@{
    ViewData["Title"] = "Nuevo Usuario";
}

@section TopbarActions {
    <a href="/User" class="btn btn-outline-secondary btn-sm">← Volver</a>
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Registrar Usuario</div>
            <div class="card-body">
                <form asp-action="Create" asp-controller="User" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Nombre</label>
                        <input asp-for="Name" class="form-control" placeholder="Ej: Juan" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Lastname" class="form-label">Apellido</label>
                        <input asp-for="Lastname" class="form-control" placeholder="Ej: García" />
                        <span asp-validation-for="Lastname" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DNI" class="form-label">DNI</label>
                        <input asp-for="DNI" class="form-control" placeholder="Ej: 1234567890" />
                        <span asp-validation-for="DNI" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Registrar</button>
                        <a href="/User" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
