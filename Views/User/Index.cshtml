@model IEnumerable<library.Models.User>
@{
    ViewData["Title"] = "Usuarios";
}

@* <span class="bg-@(status != "success" ? "danger" : "success")">@message</span> *@
@if(TempData["message"] != null){
<div class="alert alert-@(TempData["status"] == "success" ? "success" : "danger") alert-dismissible fade show" role="alert">
    @TempData["message"]
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
}
@section TopbarActions {
    <a href="/User/Create" class="btn btn-primary btn-sm">+ Nuevo Usuario</a>
}

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Listado de Usuarios</span>
        <span class="text-muted small">@Model.Count() registros</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <p class="mb-1">No hay usuarios registrados.</p>
                <a href="/User/Create" class="btn btn-outline-primary btn-sm mt-2">Registrar primero</a>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th>Apellido</th>
                        <th>DNI</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="text-muted">@user.Id</td>
                            <td>@user.Name</td>
                            <td>@user.Lastname</td>
                            <td><code>@user.DNI</code></td>
                            <td class="text-end">
                                <a asp-controller="User" asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-secondary btn-sm">Editar</a>
                                <form method="post" action="/User/Delete/@user.Id" class="d-inline"
                                      onsubmit="return confirm('¿Eliminar a @user.Name @user.Lastname?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Eliminar</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
